{
  "name": "@leonardsellem/agent-brain",
  "version": "0.2.0",
  "description": "Git-backed package and profile manager for portable AI coding-agent capabilities.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leonardsellem/agent-brain.git"
  },
  "bugs": {
    "url": "https://github.com/leonardsellem/agent-brain/issues"
  },
  "homepage": "https://github.com/leonardsellem/agent-brain#readme",
  "keywords": [
    "agent-brain",
    "ai-agents",
    "claude-code",
    "codex",
    "cli",
    "dotfiles"
  ],
  "bin": {
    "agent-brain": "dist/cli.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "docs/npm-release.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "tag": "latest"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "changeset": "changeset",
    "pack:smoke": "node scripts/pack-smoke.mjs",
    "version-packages": "changeset version",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^20.12.12",
    "typescript": "^5.4.5",
    "vitest": "^4.1.5"
  }
}
